{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "craftstack-server",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-10",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "craftstack-db",
      "database_id": "8d1f061d-7b18-4d22-be88-12a0b3f0a706",
      "migrations_dir": "drizzle"
    }
  ]
}
